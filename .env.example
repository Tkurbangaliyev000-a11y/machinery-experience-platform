# Frontend (Vite)
# For GitHub Pages, point to your deployed Cloudflare Worker URL.
VITE_LEASING_API_URL=https://your-worker-subdomain.workers.dev

# Worker-side secrets and variables
TELEGRAM_BOT_TOKEN=replace-with-secret
TELEGRAM_CHAT_ID=2054432621

# Optional: comma-separated allowlist for CORS
ALLOWED_ORIGINS=https://your-github-pages-domain.github.io
